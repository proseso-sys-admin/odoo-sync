# Source Odoo (required)
SOURCE_BASE_URL=https://your-source.odoo.com
SOURCE_DB=your-source-db
SOURCE_LOGIN=admin@example.com
SOURCE_PASSWORD=your-api-key-or-password

# State: single JSON file in Cloud Storage (bucket name, no gs://)
STATE_GCS_BUCKET=your-bucket
STATE_GCS_PATH=odoosync/state.json

# Concurrency cap for parallel target DBs (default 10)
MAX_CONCURRENT_TARGETS=10

# Batch size for attachment fetch (default 200)
ATTACHMENT_BATCH_LIMIT=200

# One-time reset: set to 1 or true to force tax cursor to 0 for the next run (rescan from start). Unset after one run.
# ODOO_SYNC_RESET_TAX_CURSOR=1

# Periodic full rescan: set to number of days (e.g. 1 or 7) to run a full rescan every N days. Catches re-uploads that reuse the same attachment id (e.g. file deleted then uploaded again).
# ODOO_SYNC_TAX_RESCAN_DAYS=1

# Optional: if set, POST /webhook requires header X-Webhook-Secret to match this value
# WEBHOOK_SECRET=your-shared-secret
