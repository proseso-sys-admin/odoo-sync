# Source Odoo — acts as service registry (reads project.task for client list)
SOURCE_BASE_URL=https://proseso-ventures.odoo.com
SOURCE_DB=proseso-ventures
SOURCE_LOGIN=
SOURCE_PASSWORD=

# Secret token embedded in URL path — guards all routes from public access
# URL becomes: https://service.run.app/{ACCESS_TOKEN}/
ACCESS_TOKEN=change-me-before-deploying

# Port (Cloud Run sets this automatically)
PORT=8080
