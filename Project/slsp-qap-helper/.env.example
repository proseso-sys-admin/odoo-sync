# Odoo client databases — JSON array injected from Secret Manager
# company_tin and company_id are fetched live from res.company — not stored here
# Format: [{"name":"AGI Entertainment","url":"https://agi-entertainment.odoo.com","db":"agi-entertainment","user":"...","api_key":"..."}]
ODOO_CLIENTS_JSON=

# Secret token embedded in URL path — guards all routes from public access
# URL becomes: https://service.run.app/{ACCESS_TOKEN}/
ACCESS_TOKEN=change-me-before-deploying

# Port (Cloud Run sets this automatically)
PORT=8080
